<Project>
   <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)\.mvdmio-translations.snapshot.json')">
      <EmbeddedResource Include="$(MSBuildProjectDirectory)\.mvdmio-translations.snapshot.json">
         <LogicalName>$(AssemblyName).mvdmio-translations.snapshot.json</LogicalName>
      </EmbeddedResource>
   </ItemGroup>
</Project>
